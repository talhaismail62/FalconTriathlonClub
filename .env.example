# Copy this file to .env and fill in your Supabase project values.
EXPO_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Strava leaderboard FastAPI backend base URL (no trailing slash).
# Local: http://<your-lan-ip>:8000   Deployed: https://stravabackend.onrender.com
EXPO_PUBLIC_LEADERBOARD_API_URL=http://localhost:8000
